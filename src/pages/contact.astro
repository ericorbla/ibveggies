    transition: all 0.3s ease;
    font-size: 16px;
  }

  .contact-social:hover {
    background-color: rgb(146, 28, 150);
  } */

  .map-section {
    margin-top: 40px;
  }
  .map-section iframe {
    border-radius: 12px;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
  }

  @media (max-width: 768px) {
    .contact-form {
      width: 90%;
    }
  }
</style>
