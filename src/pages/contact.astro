<Layout
  title="Contact Us - IB Veggies"
  description="Get in touch with IB Veggies for fresh spring onions and lettuces"
>
  <!-- HERO SECTION -->
  <section class="hero-contact">
    <div class="container">
      <h1>Contact IB Veggies</h1>
      <p>
        We're here to answer your questions and provide fresh produce solutions
        for your business.
      </p>
    </div>
  </section>

  <!-- CONTACT FORM -->
  <section class="contact-form-section">
    <div class="container">
      <h2>Send Us a Message</h2>
      <form
        class="contact-form"
        method="POST"
        action="https://formspree.io/f/xkopaqaa"
      >
        <div class="form-group">
          <label>Name</label>
          <input type="text" name="name" required />
        </div>

        <div class="form-group">
          <label>Email</label>
          <input type="email" name="email" required />
        </div>

        <div class="form-group">
          <label>Subject</label>
          <input type="text" name="subject" />
        </div>

        <div class="form-group">
          <label>Message</label>
          <textarea name="message" rows="5" required></textarea>
        </div>

        <button class="btn-submit" type="submit">Send Message</button>
      </form>
    </div>
  </section>

  <!-- COMPANY INFO -->
  <section class="company-info">
    <div class="container">
      <h2>Our Info</h2>
      <p><strong>Address:</strong> {companyInfo.address}</p>
      <p><strong>Phone:</strong> {companyInfo.phone}</p>
      <p><strong>Email:</strong> {companyInfo.email}</p>
      <!-- <div class="social-links">
        <a href={companyInfo.social.facebook} target="_blank">Facebook</a> |
        <a href={companyInfo.social.twitter} target="_blank">Twitter</a> |
        <a href={companyInfo.social.instagram} target="_blank">Instagram</a>
      </div> -->
    </div>
    <SocialMedia linkClass="contact-social" />
  </section>

  <!-- OPTIONAL MAP SECTION -->
  <section class="map-section">
    <div class="container">
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m17!1m12!1m3!1d3961.2371029782557!2d0.28335099999999996!3d6.862163000000001!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m2!1m1!2zNsKwNTEnNDMuOCJOIDDCsDE3JzAwLjEiRQ!5e0!3m2!1sen!2sgh!4v1775754288890!5m2!1sen!2sgh"
        width="100%"
        height="400"
        style="border:0;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
      >
      </iframe>
    </div>
  </section>
</Layout>
<style>
  .hero-contact {
    background-color: var(--color-accent, #1f2937);
    color: #fff;
    text-align: center;
    padding: 60px 20px;
  }

  .contact-form-section {
    padding: 50px 0px;
    background-color: #f9f9f9;
  }

  .contact-form-section h2 {
    text-align: center;
    margin-bottom: 30px;
  }

  .contact-form {
    max-width: 600px;
    margin: 0 auto;
    display: grid;
    gap: 20px;
  }

  .form-group {
    display: flex;
    flex-direction: column;
  }

  .form-group label {
    margin-bottom: 5px;
    font-weight: 500;
  }

  .form-group input,
  .form-group textarea {
    padding: 10px;
    border: 1px solid #ccc;
    border-radius: 6px;
    font-size: 16px;
  }

  .btn-submit {
    background-color: var(--color-primary);
    color: #fff;
    padding: 15px;
    border: none;
    border-radius: 6px;
    font-size: 16px;
    cursor: pointer;
    transition: background-color 0.3s ease;
  }

  .btn-submit:hover {
    background-color: #0f3d3d;
  }

  .company-info {
    padding: 50px 20px;
    text-align: center;
  }

  .company-info h2 {
    margin-bottom: 20px;
  }
