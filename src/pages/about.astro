---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import Showcase from "../components/Showcase.astro";
import Main from "../components/Main.astro";
import CEO from "../assets/ceo1.jpg"; // add your image
import Slideshow from "../components/Ourfarmslide.astro";
---

<Layout title="About Us">
  <Showcase
    heading="VEGGIES"
    subheading="WELCOME"
    text="To your One Stop Farm For Reliable Supplier of Fresh Spring Onions & Lettuce"
    showExtra={false}
  />
  <Main>
    <!-- 🔥 HERO SECTION -->

    <!-- 🌿 MISSION / VISION / MOTTO -->
    <section class="values">
      <div class="container">
        <div class="card">
          <h3>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 640 640"
              width="20"
              height="20"
              fill="currentColor"
              color="#4ade80"
            >
              <path
                d="M420.9 448C428.2 425.7 442.8 405.5 459.3 388.1C492 353.7 512 307.2 512 256C512 150 426 64 320 64C214 64 128 150 128 256C128 307.2 148 353.7 180.7 388.1C197.2 405.5 211.9 425.7 219.1 448L420.8 448zM416 496L224 496L224 512C224 556.2 259.8 592 304 592L336 592C380.2 592 416 556.2 416 512L416 496zM312 176C272.2 176 240 208.2 240 248C240 261.3 229.3 272 216 272C202.7 272 192 261.3 192 248C192 181.7 245.7 128 312 128C325.3 128 336 138.7 336 152C336 165.3 325.3 176 312 176z"
              ></path>
            </svg>
            Our Mission
          </h3>
          <p>
            To provide fresh, high-quality vegetables to homes and businesses
            with reliability and consistency.
          </p>
        </div>

        <div class="card">
          <h3>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 640 640"
              width="20"
              height="20"
              fill="currentColor"
              color="black"
            >
              <path
                d="M320 96C239.2 96 174.5 132.8 127.4 176.6C80.6 220.1 49.3 272 34.4 307.7C31.1 315.6 31.1 324.4 34.4 332.3C49.3 368 80.6 420 127.4 463.4C174.5 507.1 239.2 544 320 544C400.8 544 465.5 507.2 512.6 463.4C559.4 419.9 590.7 368 605.6 332.3C608.9 324.4 608.9 315.6 605.6 307.7C590.7 272 559.4 220 512.6 176.6C465.5 132.9 400.8 96 320 96zM176 320C176 240.5 240.5 176 320 176C399.5 176 464 240.5 464 320C464 399.5 399.5 464 320 464C240.5 464 176 399.5 176 320zM320 256C320 291.3 291.3 320 256 320C244.5 320 233.7 317 224.3 311.6C223.3 322.5 224.2 333.7 227.2 344.8C240.9 396 293.6 426.4 344.8 412.7C396 399 426.4 346.3 412.7 295.1C400.5 249.4 357.2 220.3 311.6 224.3C316.9 233.6 320 244.4 320 256z"
              ></path>
            </svg>
            Our Vision
          </h3>
          <p>
            To become a leading and trusted vegetable supplier across Ghana.
          </p>
        </div>

        <div class="card">
          <h3>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 640 640"
              width="20"
              height="20"
              fill="currentColor"
              color="red"
            >
              <path
                d="M341.5 45.1C337.4 37.1 329.1 32 320.1 32C311.1 32 302.8 37.1 298.7 45.1L225.1 189.3L65.2 214.7C56.3 216.1 48.9 222.4 46.1 231C43.3 239.6 45.6 249 51.9 255.4L166.3 369.9L141.1 529.8C139.7 538.7 143.4 547.7 150.7 553C158 558.3 167.6 559.1 175.7 555L320.1 481.6L464.4 555C472.4 559.1 482.1 558.3 489.4 553C496.7 547.7 500.4 538.8 499 529.8L473.7 369.9L588.1 255.4C594.5 249 596.7 239.6 593.9 231C591.1 222.4 583.8 216.1 574.8 214.7L415 189.3L341.5 45.1z"
              ></path>
            </svg>
            Our Motto
          </h3>
          <p>“Freshness you can trust, quality you deserve.”</p>
        </div>
      </div>
    </section>

    <!-- 👤 CEO PROFILE -->
    <section class="ceo">
      <div class="container ceo-grid">
        <Image src={CEO} alt="CEO of IB Veggies" class="slide-image" />

        <!-- <img src={CEO.src} alt="CEO of IB Veggies" /> -->

        <div class="page-content">
          <h2>Meet Our CEO</h2>
          <h3 class="ceo-name">Godsway Awutey</h3>
          <p class="ceo-role">Founder & Chief Executive Officer, IB Veggies</p>

          <p>
            Godsway Awutey is the visionary behind IB Veggies, driven by a deep
            passion for agriculture, innovation, and community development.He
            brings a unique blend of analytical thinking and creativity into the
            agricultural space.
          </p>

          <p>
            His leadership focuses on delivering high-quality, fresh produce
            while building reliable systems that connect farms directly to
            customers. Through dedication and consistency, he has positioned IB
            Veggies as a trusted supplier in Accra and beyond.
          </p>

          <p>
            Beyond business, Godsway is committed to empowering communities,
            supporting local farmers, and promoting sustainable agricultural
            practices for the future.
          </p>
        </div>
      </div>
    </section>

    <!-- 🛒 OUR SERVICES -->
    <section class="services">
      <h2>What We Offer</h2>

      <div class="container">
        <div class="service-card">
          <h3>🥬 Fresh Lettuce Supply</h3>
          <p>High-quality lettuce delivered fresh to your doorstep.</p>
        </div>

        <div class="service-card">
          <h3>🌿 Spring Onions</h3>
          <p>Clean, fresh, and ready for your kitchen or business.</p>
        </div>

        <div class="service-card">
          <h3>🚚 Bulk Delivery</h3>
          <p>Reliable supply for restaurants, vendors, and markets.</p>
        </div>
      </div>
    </section>

    <!-- 📖 OUR STORY -->
    <section class="story">
      <div class="container story-grid">
        <div class="page-content">
          <h2>Our Story</h2>
          <p>
            IB Veggies started with a simple goal — to deliver fresh vegetables
            directly from farms to customers. What began as a small initiative
            has grown into a trusted supply business serving Accra and beyond.
          </p>

          <p>
            Through dedication, quality control, and strong relationships with
            farmers, we continue to grow and serve our community better every
            day.
          </p>
        </div>
        <Slideshow autoPlayInterval={4000} />
      </div>
    </section>
  </Main>
</Layout>

<style>
  /* HERO */
  .hero {
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    text-align: center;
  }

  .hero h1 {
    font-size: 48px;
  }

  .hero p {
    font-size: 20px;
  }

  /* VALUES */
  .values .container {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    padding: 0px 0px;
  }

  .card {
    background: #f8fafc;
    padding: 20px;
    border-radius: 10px;
    text-align: center;
  }

  /* CEO */
  .ceo-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 30px;
    padding: 40px 20px;
  }

  .ceo .slide-image {
    width: 100%;
    height: 100%;
    border-radius: 10px;
  }

  /* SERVICES */
  .services {
    text-align: center;
    padding: 40px 20px;
  }

  .services .container {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .service-card {
    background: #f1f5f9;
    padding: 20px;
    border-radius: 10px;
  }

  /* STORY */
  .story-grid {
    /* display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 30px; */
  }

  .story img {
    /* border-radius: 10px; */
  }

  /* RESPONSIVE */
  @media (max-width: 768px) {
    .values .container,
    .services .container,
    .ceo-grid,
    .story-grid {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .hero h1 {
      font-size: 32px;
    }
  }
</style>
