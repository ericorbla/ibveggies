---
import { Image } from "astro:assets";
import Img1 from "../assets/background.jpeg";
import Img2 from "../assets/lettuce.jpeg";
import Img3 from "../assets/mixed-greens.jpeg";
import Img4 from "../assets/spring-onions.jpeg";

export interface Props {
  autoPlayInterval?: number;
}

const { autoPlayInterval = 5000 } = Astro.props as Props;

const slides = [
  { id: 1, image: Img1, alt: "Background" },
  { id: 2, image: Img2, alt: "Lettuce" },
  { id: 3, image: Img3, alt: "Mixed Greens" },
  { id: 4, image: Img4, alt: "Spring Onions" },
];
---

<div class="slideshow-container">
  <div class="slides-wrapper">
    {
      slides.map((slide) => (
        <div class="slide" data-slide-id={slide.id}>
          <Image src={slide.image} alt={slide.alt} class="slide-image" />
        </div>
      ))
    }
  </div>

  <!-- Navigation Buttons -->
  <button class="prev-btn" aria-label="Previous slide">❮</button>
  <button class="next-btn" aria-label="Next slide">❯</button>

  <!-- Slide Indicators -->
  <div class="indicators">
    {
      slides.map((slide, index) => (
        <button
          class={`indicator ${index === 0 ? "active" : ""}`}
          data-slide-index={index}
          aria-label={`Go to slide ${index + 1}`}
        />
      ))
    }
  </div>
</div>

<script define:vars={{ autoPlayInterval, totalSlides: slides.length }}>
  let currentSlide = 0;
  let autoPlayTimer;

  function showSlide(index) {
    const wrapper = document.querySelector(".slides-wrapper");
    const indicators = document.querySelectorAll(".indicator");

    // Wrap around
    if (index >= totalSlides) currentSlide = 0;
    if (index < 0) currentSlide = totalSlides - 1;

    // Update wrapper transform
    wrapper.style.transform = `translateX(-${currentSlide * 100}%)`;

    // Update indicators
    indicators.forEach((ind, i) => {
      ind.classList.toggle("active", i === currentSlide);
    });

    // Reset auto-play timer
    resetAutoPlay();
  }

  function nextSlide() {
    currentSlide++;
    showSlide(currentSlide);
  }

  function prevSlide() {
    currentSlide--;
    showSlide(currentSlide);
  }

  function goToSlide(index) {
    currentSlide = index;
    showSlide(currentSlide);
  }

  function resetAutoPlay() {
    clearInterval(autoPlayTimer);
    autoPlayTimer = setInterval(nextSlide, autoPlayInterval);
  }

  // Event Listeners
  document.querySelector(".next-btn")?.addEventListener("click", nextSlide);
  document.querySelector(".prev-btn")?.addEventListener("click", prevSlide);

  document.querySelectorAll(".indicator").forEach((indicator, index) => {
    indicator.addEventListener("click", () => goToSlide(index));
  });

  // Start auto-play
  resetAutoPlay();

  // Pause on hover
  document
    .querySelector(".slideshow-container")
    ?.addEventListener("mouseenter", () => {
      clearInterval(autoPlayTimer);
    });

  document
    .querySelector(".slideshow-container")
    ?.addEventListener("mouseleave", () => {
      resetAutoPlay();
    });
</script>

<style>
  .slideshow-container {
    position: relative;
    width: 100%;
    max-width: 1000px;
    margin: 0 auto;
    overflow: hidden;
    border-radius: 10px;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
  }

  .slides-wrapper {
    display: flex;
    transition: transform 0.6s ease-in-out;
  }

  .slide {
    min-width: 100%;
    flex: 0 0 100%;
  }

  .slide-image {
    width: 100%;
    height: 400px;
    object-fit: cover;
    display: block;
  }

  /* Navigation Buttons */
  .prev-btn,
  .next-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background-color: rgba(0, 0, 0, 0.5);
    color: white;
    border: none;
    font-size: 24px;
    padding: 15px 18px;
    cursor: pointer;
    border-radius: 5px;
    transition: background-color 0.3s ease;
    z-index: 10;
  }

  .prev-btn:hover,
  .next-btn:hover {
    background-color: rgba(0, 0, 0, 0.8);
  }

  .prev-btn {
    left: 15px;
  }

  .next-btn {
    right: 15px;
  }

  /* Indicators */
  .indicators {
    position: absolute;
    bottom: 15px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 8px;
    z-index: 10;
  }

  .indicator {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background-color: rgba(255, 255, 255, 0.5);
    border: none;
    cursor: pointer;
    transition:
      background-color 0.3s ease,
      transform 0.3s ease;
  }

  .indicator:hover {
    background-color: rgba(255, 255, 255, 0.8);
    transform: scale(1.2);
  }

  .indicator.active {
    background-color: rgba(255, 255, 255, 1);
    transform: scale(1.3);
  }

  @media (max-width: 768px) {
    .slide-image {
      height: 250px;
    }

    .prev-btn,
    .next-btn {
      font-size: 18px;
      padding: 10px 12px;
    }

    .indicator {
      width: 10px;
      height: 10px;
    }
  }
</style>
