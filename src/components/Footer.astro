---
const year = new Date().getFullYear();
const locations = ["Anlgo, kportorgbey"];
import Image from "../images/iblogo.png";
---

<footer class="footer">
  <div class="container">
    <!-- Company Info -->
    <div class="footer-section">
      <h2><img src={Image.src} alt="IB VEGGIES logo" /> VEGGIES</h2>
      <p>
        Supplying fresh spring onions and lettuce to businesses in
        {locations.join(" and ")}. Quality, reliability, and freshness
        guaranteed.
      </p>
    </div>

    <!-- Quick Links -->
    <div class="footer-section">
      <h3>Quick Links</h3>
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/services">Services</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
    </div>

    <!-- Contact Info -->
    <div class="footer-section">
      <h3>Contact Us</h3>
      <p>📍 {locations.join(" & ")}</p>
      <p>📞 +233 550 526 255</p>
      <p>📧 awuteygodsway7@gmail.com</p>
    </div>

    <!-- Newsletter / CTA -->
    <div class="footer-section">
      <h3>Stay Updated</h3>
      <p>Get updates on fresh produce and availability.</p>
      <form onsubmit="event.preventDefault()">
        <input type="email" placeholder="Enter your email" required />
        <button type="submit">Subscribe</button>
      </form>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="footer-bottom">
    <p>© {year} IB VEGGIES. All rights reserved.</p>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-primary, #1f2937);
    color: #eafbe9;
    padding-top: 40px;
  }
  .footer img {
    height: 50px;
    vertical-align: middle;
  }

  .footer .container {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 30px;
    max-width: 1100px;
    margin: auto;
    padding: 0 20px;
  }

  .footer-section h2,
  .footer-section h3 {
    margin-bottom: 15px;
    vertical-align: middle;
  }

  .footer-section p {
    font-size: 14px;
    line-height: 1.6;
    color: #ccc;
  }

  .footer-section ul {
    list-style: none;
    padding: 0;
  }

  .footer-section ul li {
    margin-bottom: 10px;
  }

  .footer-section ul li a {
    color: #ccc;
    text-decoration: none;
    transition: color 0.3s;
  }

  .footer-section ul li a:hover {
    color: #22c55e;
  }

  /* Form */
  .footer-section form {
    display: flex;
    gap: 10px;
    margin-top: 10px;
  }

  .footer-section input {
    padding: 10px;
    border: none;
    border-radius: 4px;
    width: 100%;
    outline: none;
  }

  .footer-section button {
    padding: 10px 14px;
    background: #22c55e;
    border: none;
    color: white;
    cursor: pointer;
    border-radius: 4px;
    transition: background 0.3s;
  }

  .footer-section button:hover {
    background: #16a34a;
  }

  /* Bottom */
  .footer-bottom {
    text-align: center;
    padding: 20px;
    margin-top: 30px;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    font-size: 14px;
    color: #aaa;
  }

  /* ✅ Responsive */
  @media (max-width: 900px) {
    .footer .container {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .footer .container {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .footer-section form {
      flex-direction: column;
    }

    .footer-section button {
      width: 100%;
    }
  }
</style>
