---
const updates = [
  {
    title: "Fresh Vegetables Available Today",
    date: "2026-04-11",
    content: `
      We have fresh, lettuce, and spring onions available today.
      Order early before stock runs out!
    `,
  },
  {
    title: "New Stock Coming Tomorrow",
    date: "2026-04-10",
    content: `
      Expect new arrivals of peppers and cucumbers tomorrow morning.
    `,
  },
];

// Get latest
const latest = updates
  .filter((u) => u.date)
  .sort((a, b) => {
    const dateA = new Date(a.date).getTime();
    const dateB = new Date(b.date).getTime();
    return dateB - dateA;
  })[0];
---

{
  latest ? (
    <section id="updates" class="updates">
      <h2>{latest.title}</h2>

      <div class="share-buttons">
        <button id="copy-link">Copy Link</button>
        <button id="share-link">Share</button>
      </div>

      <div class="update-content">
        <p>{latest.content}</p>
      </div>
    </section>
  ) : (
    <p />
  )
}

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const sectionLink = window.location.origin + window.location.pathname;

    const copyBtn = document.getElementById("copy-link");
    const shareBtn = document.getElementById("share-link");

    // Copy link
    copyBtn?.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(sectionLink);
        copyBtn.textContent = "Copied!";
        setTimeout(() => {
          copyBtn.textContent = "Copy Link";
        }, 2000);
      } catch (err) {
        alert("Failed to copy link");
      }
    });

    // Share link
    shareBtn?.addEventListener("click", async () => {
      if (navigator.share) {
        try {
          await navigator.share({
            title: "IB Veggies Availability",
            text: "Check today's fresh veggies availability 🌱",
            url: sectionLink,
          });
        } catch (err) {
          console.log("Share cancelled or failed");
        }
      } else {
        alert("Sharing not supported on this device");
      }
    });
  });
</script>

<style>
  .updates {
    padding: 50px 20px;
    background: #f9f9f9;
  }

  .updates h2 {
    text-align: center;
    margin-bottom: 20px;
  }

  .update-content {
    max-width: 700px;
    margin: auto;
    font-size: 18px;
    line-height: 1.6;
  }
  p {
    text-align: center;
  }

  .update-content h2 {
    font-size: 20px;
    margin-top: 20px;
  }

  .share-buttons {
    display: flex;
    justify-content: center;
    gap: 10px;
    margin-bottom: 20px;
  }

  .share-buttons button {
    padding: 10px 15px;
    border: none;
    background: var(--color-primary);
    color: white;
    border-radius: 6px;
    cursor: pointer;
    transition: 0.3s;
  }

  .share-buttons button:hover {
    background: #0f3d3d;
  }
</style>
